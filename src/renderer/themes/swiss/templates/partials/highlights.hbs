{{#if aiContent.highlights.length}}
<div class="section-row">
  <div class="section-num">02</div>
  <div class="section-content">
    <div class="section-group-header">
      <span class="section-group-title">{{i18n.sectionHighlights}}</span>
      <span class="section-group-count">{{itemsCount aiContent.highlights.length}}</span>
    </div>

    <div class="highlight-grid">
    {{#each aiContent.highlights}}
    <div class="highlight-card">
      <span class="highlight-badge highlight-{{this.type}}">{{this.type}}</span>
      {{#if this.url}}
      <div class="highlight-title"><a href="{{this.url}}" target="_blank" rel="noopener nofollow">{{this.title}}</a></div>
      {{else}}
      <div class="highlight-title">{{this.title}}</div>
      {{/if}}
      <div class="highlight-meta">{{this.repo}} &middot; {{this.meta}}</div>
      <div class="highlight-body">{{{mdInline this.body}}}</div>
    </div>
    {{/each}}
    </div>
  </div>
</div>
{{/if}}
