{{#if aiContent.summaries.length}}
<div class="section-group">
  <div class="section-group-header">
    <h2 class="section-group-title">Summary</h2>
    <div class="section-group-line"></div>
    <span class="section-group-count">{{aiContent.summaries.length}} sections</span>
  </div>

  {{#each aiContent.summaries}}
  <div class="section-summary">
    <div class="section-type">{{this.type}}</div>
    <div class="section-heading">{{this.heading}}</div>
    <div class="section-body">{{this.body}}</div>

    {{! Language summary: show inline bar + colored tags }}
    {{#eq this.type "language-summary"}}
    {{#if @root.languages.length}}
    <div class="lang-bar">
      {{#each @root.languages}}
      <div style="flex:{{this.percentage}};background:{{this.color}}"></div>
      {{/each}}
    </div>
    <div class="lang-tags">
      {{#each @root.languages}}
      <span><span class="lang-dot" style="background:{{this.color}}"></span> {{this.language}} {{fixed this.percentage 0}}%</span>
      {{/each}}
    </div>
    {{/if}}
    {{/eq}}

    {{! Activity pattern: show mini heatmap }}
    {{#eq this.type "activity-pattern"}}
    {{#if @root.dailyCommits.length}}
    <div class="mini-heatmap">
      {{#each @root.dailyCommits}}
      <div class="mh-day">
        <div class="mh-block mh-level-{{heatmapLevel this.count}}">{{this.count}}</div>
        <div class="mh-label">{{weekday this.date}}</div>
      </div>
      {{/each}}
    </div>
    {{/if}}
    {{/eq}}

    {{! Chips for all other types (language/activity already have their own visuals) }}
    {{#neq this.type "language-summary"}}
    {{#neq this.type "activity-pattern"}}
    {{#if this.chips}}
    <div class="data-chips">
      {{#each this.chips}}
      <span class="chip"><span class="chip-label">{{this.label}}</span> <span class="chip-value chip-{{this.color}}">{{this.value}}</span></span>
      {{/each}}
    </div>
    {{/if}}
    {{/neq}}
    {{/neq}}
  </div>
  {{/each}}
</div>
{{/if}}
