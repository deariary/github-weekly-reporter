{{#if aiContent.highlights.length}}
<div class="section-group">
  <div class="section-group-header">
    <h2 class="section-group-title">Highlights</h2>
    <div class="section-group-line"></div>
    <span class="section-group-count">{{aiContent.highlights.length}} items</span>
  </div>

  {{#each aiContent.highlights}}
  <div class="highlight-card">
    <span class="highlight-badge highlight-{{this.type}}">{{this.type}}</span>
    <div class="highlight-title">{{this.title}}</div>
    <div class="highlight-meta">{{this.repo}} · {{this.meta}}</div>
    <div class="highlight-body">{{this.body}}</div>
  </div>
  {{/each}}
</div>
{{/if}}
