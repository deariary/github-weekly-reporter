<!DOCTYPE html>
<html lang="{{lang}}">
<head>
  <title>{{aiContent.title}} - {{dateRange.from}} - {{dateRange.to}}</title>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="{{aiContent.subtitle}}" />
  <meta property="og:title" content="{{aiContent.title}}" />
  <meta property="og:description" content="{{aiContent.subtitle}}" />
  <meta property="og:image" content="{{{ogImageUrl}}}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content="article" />
  {{#if canonicalUrl}}<meta property="og:url" content="{{{canonicalUrl}}}" />
  {{/if}}<meta property="og:site_name" content="{{username}} Weekly Reports" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{aiContent.title}}" />
  <meta name="twitter:description" content="{{aiContent.subtitle}}" />
  <meta name="twitter:image" content="{{{ogImageUrl}}}" />
  {{#if canonicalUrl}}<link rel="canonical" href="{{{canonicalUrl}}}" />
  {{/if}}<meta name="view-transition" content="same-origin" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{{aiContent.title}}}",
    "description": "{{{aiContent.subtitle}}}",
    "author": {
      "@type": "Person",
      "name": "{{{username}}}",
      "url": "https://github.com/{{{username}}}"
    },
    "image": "{{{ogImageUrl}}}",
    "datePublished": "{{{dateRange.to}}}"
  }
  </script>
  {{#if canonicalUrl}}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{{baseUrl}}}/" },
      { "@type": "ListItem", "position": 2, "name": "{{dateRange.from}} - {{dateRange.to}}", "item": "{{{canonicalUrl}}}" }
    ]
  }
  </script>
  {{/if}}
  <style>{{{css}}}</style>
</head>
<body>

<nav>
  <a href="../../" class="nav-left">
    <img src="{{avatarUrl}}" alt="{{username}}" />
    <span>{{username}}</span>
  </a>
  <a href="../../" class="nav-back">&larr; {{i18n.allWeeks}}</a>
</nav>

<div class="page">
  {{> header}}
  {{> overview}}
  {{> summaries}}
  {{> highlights}}
</div>

{{#if prevWeek}}{{#if nextWeek}}
<nav class="week-nav">
  <a href="{{prevWeek}}" class="week-nav-link">&larr; {{i18n.prevWeek}}</a>
  <a href="{{nextWeek}}" class="week-nav-link">{{i18n.nextWeek}} &rarr;</a>
</nav>
{{else}}
<nav class="week-nav">
  <a href="{{prevWeek}}" class="week-nav-link">&larr; {{i18n.prevWeek}}</a>
  <span></span>
</nav>
{{/if}}{{else}}{{#if nextWeek}}
<nav class="week-nav">
  <span></span>
  <a href="{{nextWeek}}" class="week-nav-link">{{i18n.nextWeek}} &rarr;</a>
</nav>
{{/if}}{{/if}}

{{> footer}}

</body>
</html>
